<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tomato_arm">

    <!-- ===================================================== -->
    <!-- CAMERA PARAMETERS                                     -->
    <!-- ===================================================== -->

    <!--
        base_link convention:

        +X = forward
        -X = backward
        +Y = robot-left
        -Y = robot-right
        +Z = upward
    -->

    <!-- Both camera lens centers are 20 cm behind the shoulder -->
    <xacro:property name="camera_x" value="-0.20"/>

    <!-- Camera lens centers are 65 cm above base_link -->
    <xacro:property name="camera_height" value="0.65"/>

    <!-- 41 degrees downward -->
    <xacro:property name="camera_pitch" value="0.715585"/>

    <!-- Distance between the two camera lens centers -->
    <xacro:property name="camera_baseline" value="0.10"/>


    <!-- ===================================================== -->
    <!-- MATERIALS                                             -->
    <!-- ===================================================== -->

    <material name="color1">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>

    <material name="color2">
        <color rgba="0.0 0.8 0.0 1.0"/>
    </material>

    <material name="color3">
        <color rgba="0.0 0.35 1.0 1.0"/>
    </material>

    <material name="color4">
        <color rgba="1.0 0.85 0.0 1.0"/>
    </material>

    <material name="color5">
        <color rgba="0.65 0.20 0.85 1.0"/>
    </material>


    <!-- ===================================================== -->
    <!-- ROBOT ARM                                             -->
    <!-- ===================================================== -->

    <link name="base_link">
        <visual>
            <!--
                Rotate only the base STL by 90 degrees.

                This does not rotate base_link, the arm,
                the camera transforms, or the IK coordinate frame.
            -->
            <origin xyz="0 0 0" rpy="0 0 1.5708"/>

            <geometry>
                <mesh
                    filename="package://tomato_description/meshes/base_link.stl"/>
            </geometry>

            <material name="color1"/>
        </visual>
    </link>


    <joint name="joint_1" type="continuous">
        <parent link="base_link"/>
        <child link="shoulder_link"/>

        <!-- Arm orientation already matches the real robot -->
        <origin xyz="0 0 0" rpy="0 0 0"/>

        <axis xyz="0 0 1"/>
        <limit effort="1.0" velocity="2.0"/>
    </joint>


    <link name="shoulder_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>

            <geometry>
                <mesh
                    filename="package://tomato_description/meshes/shoulder_link.stl"/>
            </geometry>

            <material name="color2"/>
        </visual>
    </link>


    <joint name="joint_2" type="revolute">
        <parent link="shoulder_link"/>
        <child link="forearm_link"/>

        <origin xyz="0 0 0.10597" rpy="0 -1.5708 0"/>

        <axis xyz="0 1 0"/>

        <limit
            lower="-1.618"
            upper="1.595"
            effort="1.0"
            velocity="2.0"/>
    </joint>


    <link name="forearm_link">
        <visual>
            <origin xyz="0 0 -0.10597" rpy="0 0 0"/>

            <geometry>
                <mesh
                    filename="package://tomato_description/meshes/forearm_link.stl"/>
            </geometry>

            <material name="color3"/>
        </visual>
    </link>


    <joint name="joint_3" type="revolute">
        <parent link="forearm_link"/>
        <child link="elbow_link"/>

        <origin xyz="0.1778 0 0" rpy="0 0 0"/>

        <axis xyz="0 1 0"/>

        <limit
            lower="-1.825"
            upper="1.792"
            effort="1.0"
            velocity="2.0"/>
    </joint>


    <link name="elbow_link">
        <visual>
            <origin xyz="-0.1778 0 -0.10597" rpy="0 0 0"/>

            <geometry>
                <mesh
                    filename="package://tomato_description/meshes/elbow_link.stl"/>
            </geometry>

            <material name="color4"/>
        </visual>
    </link>


    <joint name="joint_4" type="revolute">
        <parent link="elbow_link"/>
        <child link="wrist_link"/>

        <origin xyz="0.1524 0 0" rpy="0 0 0"/>

        <axis xyz="0 1 0"/>

        <limit
            lower="-1.855"
            upper="1.786"
            effort="1.0"
            velocity="2.0"/>
    </joint>


    <link name="wrist_link">
        <visual>
            <origin xyz="-0.3302 0 -0.10597" rpy="0 0 0"/>

            <geometry>
                <mesh
                    filename="package://tomato_description/meshes/wrist_link.stl"/>
            </geometry>

            <material name="color5"/>
        </visual>
    </link>


    <joint name="joint_5" type="fixed">
        <parent link="wrist_link"/>
        <child link="end_effector_link"/>

        <origin xyz="0.0345 0 0" rpy="0 0 0"/>
    </joint>


    <link name="end_effector_link">
        <visual>
            <origin xyz="-0.3647 0 -0.10597" rpy="0 0 0"/>

            <geometry>
                <mesh
                    filename="package://tomato_description/meshes/end_effector_link.stl"
                    scale="0.001 0.001 0.001"/>
            </geometry>

            <material name="color5"/>
        </visual>
    </link>


    <link name="tool_tip_link"/>

    <joint name="tool_tip_joint" type="fixed">
        <parent link="end_effector_link"/>
        <child link="tool_tip_link"/>

        <origin xyz="0.124 0 0.04416" rpy="0 0 0"/>
    </joint>


    <!-- ===================================================== -->
    <!-- CAMERA STAND                                          -->
    <!-- ===================================================== -->

    <link name="camera_stand_link">
        <visual>
            <!--
                The camera_stand_link frame is at its bottom.
                The box is centered so it extends from z=0 to z=0.65.
            -->
            <origin
                xyz="0 0 ${camera_height / 2.0}"
                rpy="0 0 0"/>

            <geometry>
                <box size="0.03 0.03 ${camera_height}"/>
            </geometry>

            <material name="color3"/>
        </visual>
    </link>


    <joint name="camera_stand_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_stand_link"/>

        <!-- Stand is 20 cm behind the shoulder along -X -->
        <origin
            xyz="${camera_x} 0 0"
            rpy="0 0 0"/>
    </joint>


    <!-- ===================================================== -->
    <!-- CAMERA MOUNT                                          -->
    <!-- ===================================================== -->

    <link name="camera_mount_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>

            <geometry>
                <!-- Crossbar extends left/right along Y -->
                <box size="0.04 0.16 0.03"/>
            </geometry>

            <material name="color4"/>
        </visual>
    </link>


    <joint name="camera_mount_joint" type="fixed">
        <parent link="camera_stand_link"/>
        <child link="camera_mount_link"/>

        <!--
            No forward position offset.

            The lens centers remain at x = -0.20 m.

            Positive pitch rotates local +X toward:
              +X forward
              -Z downward
        -->
        <origin
            xyz="0 0 ${camera_height}"
            rpy="0 ${camera_pitch} 0"/>
    </joint>


    <!-- ===================================================== -->
    <!-- LEFT CAMERA                                           -->
    <!-- ===================================================== -->

    <link name="left_camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>

            <geometry>
                <box size="0.035 0.025 0.025"/>
            </geometry>

            <material name="color1"/>
        </visual>
    </link>


    <joint name="left_camera_joint" type="fixed">
        <parent link="camera_mount_link"/>
        <child link="left_camera_link"/>

        <!-- Left camera is at Y = +5 cm -->
        <origin
            xyz="0 ${camera_baseline / 2.0} 0"
            rpy="0 0 0"/>
    </joint>


    <!-- ===================================================== -->
    <!-- RIGHT CAMERA                                          -->
    <!-- ===================================================== -->

    <link name="right_camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>

            <geometry>
                <box size="0.035 0.025 0.025"/>
            </geometry>

            <material name="color1"/>
        </visual>
    </link>


    <joint name="right_camera_joint" type="fixed">
        <parent link="camera_mount_link"/>
        <child link="right_camera_link"/>

        <!-- Right camera is at Y = -5 cm -->
        <origin
            xyz="0 ${-camera_baseline / 2.0} 0"
            rpy="0 0 0"/>
    </joint>


    <!-- ===================================================== -->
    <!-- CAMERA OPTICAL FRAMES                                 -->
    <!-- ===================================================== -->

    <link name="left_camera_optical_frame"/>

    <joint name="left_camera_optical_joint" type="fixed">
        <parent link="left_camera_link"/>
        <child link="left_camera_optical_frame"/>

        <!--
            ROS optical convention:

            +Z = viewing direction
            +X = image right
            +Y = image down
        -->
        <origin
            xyz="0 0 0"
            rpy="-1.5708 0 -1.5708"/>
    </joint>


    <link name="right_camera_optical_frame"/>

    <joint name="right_camera_optical_joint" type="fixed">
        <parent link="right_camera_link"/>
        <child link="right_camera_optical_frame"/>

        <origin
            xyz="0 0 0"
            rpy="-1.5708 0 -1.5708"/>
    </joint>

</robot>