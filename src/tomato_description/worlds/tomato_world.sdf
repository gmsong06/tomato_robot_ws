                    <geometry>
                        <cylinder>
                            <radius>0.004</radius>
                            <length>0.11</length>
                        </cylinder>
                    </geometry>

                    <material>
                        <ambient>0.05 0.26 0.04 1</ambient>
                        <diffuse>0.08 0.40 0.06 1</diffuse>
                    </material>
                </visual>


                <!-- Low left branch -->
