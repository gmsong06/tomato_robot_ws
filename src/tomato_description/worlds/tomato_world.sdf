<?xml version="1.0"?>

<sdf version="1.10">
    <world name="default">

        <!-- ================================================= -->
        <!-- GAZEBO SYSTEMS                                    -->
        <!-- ================================================= -->

        <plugin
            filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics">
        </plugin>

        <plugin
            filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
        </plugin>

        <plugin
            filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
        </plugin>

        <plugin
            filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">

            <!-- Ogre 1 is required on your Pi -->
            <render_engine>ogre</render_engine>
        </plugin>


        <!-- ================================================= -->
        <!-- LIGHTING                                          -->
        <!-- ================================================= -->

        <scene>
            <ambient>0.55 0.55 0.55 1</ambient>
            <background>0.65 0.78 0.90 1</background>
            <shadows>true</shadows>
        </scene>

        <light name="sun" type="directional">
            <cast_shadows>true</cast_shadows>
            <pose>0 0 10 0 0 0</pose>

            <diffuse>0.9 0.9 0.85 1</diffuse>
            <specular>0.15 0.15 0.15 1</specular>

            <direction>-0.5 0.2 -0.9</direction>
        </light>


        <!-- ================================================= -->
        <!-- GROUND                                            -->
        <!-- ================================================= -->

        <model name="ground_plane">
            <static>true</static>

            <link name="ground_link">
                <collision name="ground_collision">
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>10 10</size>
                        </plane>
                    </geometry>
                </collision>

                <visual name="ground_visual">
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>10 10</size>
                        </plane>
                    </geometry>

                    <material>
                        <ambient>0.30 0.22 0.12 1</ambient>
                        <diffuse>0.38 0.28 0.15 1</diffuse>
                        <specular>0.02 0.02 0.02 1</specular>
                    </material>
                </visual>
            </link>
        </model>


        <!-- ================================================= -->
        <!-- TOMATO PLANT                                      -->
        <!-- ================================================= -->

        <model name="tomato_plant">

            <!-- Root position relative to robot base -->
            <pose>0.42 0 0 0 0 0</pose>

            <!-- Static for camera-position testing -->
            <static>true</static>

            <link name="plant_link">

                <!-- ========================================= -->
                <!-- SOIL MOUND                                -->
                <!-- ========================================= -->

                <visual name="soil_mound">
                    <pose>0 0 0.012 0 0 0</pose>

                    <geometry>
                        <cylinder>
                            <radius>0.16</radius>
                            <length>0.024</length>
                        </cylinder>
                    </geometry>

                    <material>
                        <ambient>0.20 0.10 0.04 1</ambient>
                        <diffuse>0.30 0.15 0.06 1</diffuse>
                    </material>
                </visual>


                <!-- ========================================= -->
                <!-- SUPPORT STAKE                             -->
                <!-- ========================================= -->

                <visual name="support_stake">
                    <pose>-0.035 -0.075 0.30 0 0 0</pose>

                    <geometry>
                        <cylinder>
                            <radius>0.006</radius>
                            <length>0.60</length>
                        </cylinder>
                    </geometry>

                    <material>
                        <ambient>0.32 0.18 0.08 1</ambient>
                        <diffuse>0.45 0.28 0.12 1</diffuse>
                    </material>
                </visual>


                <!-- ========================================= -->
                <!-- MAIN STEM                                 -->
                <!-- ========================================= -->

                <visual name="main_stem">
                    <pose>0 0 0.275 0 0 0</pose>

                    <geometry>
                        <cylinder>
                            <radius>0.008</radius>
                            <length>0.55</length>
                        </cylinder>
                    </geometry>

                    <material>
                        <ambient>0.05 0.28 0.04 1</ambient>
                        <diffuse>0.08 0.42 0.06 1</diffuse>
                    </material>
                </visual>

                <collision name="main_stem_collision">
                    <pose>0 0 0.275 0 0 0</pose>

                    <geometry>
                        <cylinder>
                            <radius>0.010</radius>
                            <length>0.55</length>
                        </cylinder>
                    </geometry>
                </collision>


                <!-- ========================================= -->
                <!-- BRANCHES                                  -->
                <!-- ========================================= -->

                <!-- Lower branch extending forward/right -->
                <visual name="branch_lower_forward">
                    <pose>0.075 -0.015 0.21 0 1.197 -0.197</pose>

                    <geometry>
                        <cylinder>
                            <radius>0.005</radius>
                            <length>0.165</length>
                        </cylinder>
                    </geometry>

                    <material>
                        <ambient>0.05 0.26 0.04 1</ambient>
                        <diffuse>0.08 0.40 0.06 1</diffuse>
                    </material>
                </visual>


                <!-- Middle branch extending left -->
