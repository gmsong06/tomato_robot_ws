                <!-- ========================================= -->
                <!-- CHERRY TOMATO CLUSTERS                    -->
                <!-- ========================================= -->

                <!--
                    Plant root is at world x = 0.42 m.
                    Local fruit x values stay within approximately
                    -0.036 to +0.035 m, placing fruit centers around
                    x = 0.384 to 0.455 m in front of the robot.

                    Cherry-tomato radii are 0.012 to 0.017 m,
                    giving diameters of approximately 2.4 to 3.4 cm.

                    Fruit is visual-only for lightweight camera-pose
                    testing on the Raspberry Pi.
                -->

                <!-- Main stems supporting the fruit clusters -->
                <visual name="lower_cluster_stem">
                    <pose>0.005 -0.050 0.205 0.300 0.220 0.000</pose>
                    <geometry>
                        <cylinder>
                            <radius>0.0026</radius>
                            <length>0.075</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.03 0.25 0.02 1</ambient>
                        <diffuse>0.05 0.42 0.03 1</diffuse>
